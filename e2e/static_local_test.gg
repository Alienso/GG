// End-to-end test for C-style static local variables (Phase 3).
// A `static` local is a single persistent global: it keeps its value across
// calls and is initialised exactly once before main.

// Persistent call counter — increments and returns on every call.
i32 next() {
    static i32 counter = 0;
    counter = counter + 1;
    return counter;
}

// Accumulator with a non-trivial constant initializer (runs once, pre-main).
i32 accumulate(i32 amount) {
    static i32 total = 2 + 3;   // starts at 5
    total = total + amount;
    return total;
}

// A second function with an identically named static local must be independent.
i32 other() {
    static i32 counter = 100;
    counter = counter + 1;
    return counter;
}

i32 main() {
    // Each call advances the same shared counter.
    if (next() != 1) { return 1; }
    if (next() != 2) { return 2; }
    if (next() != 3) { return 3; }

    // Independent storage from next()'s counter, with its own initial value.
    if (other() != 101) { return 4; }
    if (other() != 102) { return 5; }

    // The next() counter is untouched by other().
    if (next() != 4) { return 6; }

    // Non-zero constant initializer applied once; then accumulates.
    if (accumulate(10) != 15) { return 7; }
    if (accumulate(20) != 35) { return 8; }

    return 0;
}
