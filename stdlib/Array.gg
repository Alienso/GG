import "crt/cmem.gg";

class Array<T> {

    ptr<T> data;
    u64 size;
    u64 capacity;

    Array() {
        this.size = 0;
        this.capacity = 8;
        this.data = malloc(capacity);
    }

    ~Array(){
        free(this.data);
    }

}

impl <T> Index for Array<T> {
    fn get(i32 i) -> T {
        return data[i];
    }
    fn set(i32 i, T data) -> void {
        this.data[i] = data;
    }
}