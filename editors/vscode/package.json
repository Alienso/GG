{
  "name": "gg-lang",
  "displayName": "GG Language",
  "description": "Syntax highlighting for the GG programming language (.gg)",
  "version": "0.1.0",
  "publisher": "gg-lang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "gg",
        "aliases": [
          "GG",
          "gg"
        ],
        "extensions": [
          ".gg"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gg",
        "scopeName": "source.gg",
        "path": "./syntaxes/gg.tmLanguage.json"
      }
    ]
  }
}
