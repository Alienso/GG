// e2e/pass_by_reference_test.gg
//
// End-to-end validation of the calling convention:
//   * class/object arguments are passed BY REFERENCE (mutations propagate)
//   * basic types (i*/u*/f*/bool) are passed BY VALUE (mutations stay local)
//   * the object reference itself is immutable, but its fields are mutable
//
// Also exercises the `as` cast operator where it interacts with references.
//
// Each check returns a unique number on failure; main returns 0 when every
// check passes.  Section labels are printed so progress is visible.
//
// Expected result: exit code 0
//
//   === Test 1: object field mutation propagates ===
//   ... (one label per section) ...
//   === ALL PASS-BY-REFERENCE TESTS PASSED ===
//   exit code: 0

import "../stdlib/io.gg";

// ============================================================
// Types
// ============================================================

class Vec3 {
    public i32 x;
    public i32 y;
    public i32 z;

    public Vec3(i32 a, i32 b, i32 c) { this.x = a; this.y = b; this.z = c; }

    // Mutates self — change must be visible to the caller.
    public void scale(i32 k) {
        this.x = this.x * k;
        this.y = this.y * k;
        this.z = this.z * k;
    }

    // Reads self.
    public i32 sum() { return this.x + this.y + this.z; }

    // Takes ANOTHER object by reference and writes into it.
    public void copyInto(Vec3 dest) {
        dest.x = this.x;
        dest.y = this.y;
        dest.z = this.z;
    }

    // Takes another object by reference and reads from it (adds into self).
    public void addVec(Vec3 other) {
        this.x = this.x + other.x;
        this.y = this.y + other.y;
        this.z = this.z + other.z;
    }
}

class Box {
    public f32 val;
    public Box(f32 v) { this.val = v; }
}

// ============================================================
// Free functions
// ============================================================

// Mutate one field through a reference.
void addX(Vec3 v, i32 d) { v.x = v.x + d; }

// Mutate every field through a reference.
void bumpAll(Vec3 v) {
    v.x = v.x + 1;
    v.y = v.y + 1;
    v.z = v.z + 1;
}

// Basic type: by value — the caller's variable must be unchanged.
void tryMutateInt(i32 n) { n = n + 100; }

// Mixed: the object is mutated (visible), the int is copied (not visible).
void mixed(Vec3 v, i32 n) {
    v.x = v.x + n;
    n   = n + 1;
}

// Two distinct object references, both mutated.
void addToBoth(Vec3 a, Vec3 b, i32 d) {
    a.x = a.x + d;
    b.x = b.x + d;
}

// Chain: the same reference is threaded one level deeper.
void inner(Vec3 v) { v.x = v.x + 5; }
void outer(Vec3 v) {
    inner(v);
    v.y = v.y + 5;
}

// Swap the x fields of two referenced objects.
void swapX(Vec3 a, Vec3 b) {
    i32 t = a.x;
    a.x = b.x;
    b.x = t;
}

// Conditional mutation — only writes on the true branch.
void maybeZeroX(Vec3 v, bool doIt) {
    if (doIt) { v.x = 0; }
}

// Accumulate into a referenced object inside a loop.
void sumInto(Vec3 acc, i32 upto) {
    for (i32 i = 1; i <= upto; i++) {
        acc.x = acc.x + i;
    }
}

// Invoke a mutating method through a referenced parameter.
void scaleThrough(Vec3 v, i32 k) { v.scale(k); }

// Read fields through a reference and return a computed value.
i32 sumOf(Vec3 v) { return v.x + v.y + v.z; }

// Read an f32 field through a reference and cast it to i32.
i32 readAsInt(Box b) { return b.val as i32; }

// ============================================================
// main
// ============================================================

i32 main() {

    // ---- 1: single-field mutation propagates --------------------------
    puts("=== Test 1: object field mutation propagates ===");
    Vec3 a(10, 20, 30);
    addX(a, 5);
    if (a.x != 15) { return 1; }

    // ---- 2: basic types stay by value ---------------------------------
    puts("=== Test 2: basic types stay by value ===");
    i32 n = 7;
    tryMutateInt(n);
    if (n != 7) { return 2; }

    // ---- 3-4: mixed object + basic params -----------------------------
    puts("=== Test 3: mixed object + basic params ===");
    Vec3 b(1, 2, 3);
    i32 m = 100;
    mixed(b, m);
    if (b.x != 101) { return 3; }   // object change IS visible
    if (m   != 100) { return 4; }   // int change is NOT visible

    // ---- 5-7: mutate every field --------------------------------------
    puts("=== Test 4: mutate all fields ===");
    Vec3 c(0, 0, 0);
    bumpAll(c);
    if (c.x != 1) { return 5; }
    if (c.y != 1) { return 6; }
    if (c.z != 1) { return 7; }

    // ---- 8-9: two distinct object params ------------------------------
    puts("=== Test 5: two distinct object params ===");
    Vec3 d(1, 0, 0);
    Vec3 e(2, 0, 0);
    addToBoth(d, e, 10);
    if (d.x != 11) { return 8; }
    if (e.x != 12) { return 9; }

    // ---- 10-11: distinct objects do NOT alias -------------------------
    puts("=== Test 6: distinct objects do not alias ===");
    Vec3 f(5, 0, 0);
    Vec3 g(9, 0, 0);
    addX(f, 1);
    if (f.x != 6) { return 10; }
    if (g.x != 9) { return 11; }    // g must be untouched

    // ---- 12: aliasing — same object passed as two arguments -----------
    puts("=== Test 7: aliasing the same object twice ===");
    Vec3 h(0, 0, 0);
    addToBoth(h, h, 3);             // both params alias h: +3 applied twice
    if (h.x != 6) { return 12; }

    // ---- 13-14: reference survives a call chain -----------------------
    puts("=== Test 8: reference through a call chain ===");
    Vec3 chained(0, 0, 0);
    outer(chained);
    if (chained.x != 5) { return 13; }
    if (chained.y != 5) { return 14; }

    // ---- 15-17: a method mutates self ---------------------------------
    puts("=== Test 9: method mutates self ===");
    Vec3 j(1, 2, 3);
    j.scale(2);
    if (j.x != 2) { return 15; }
    if (j.y != 4) { return 16; }
    if (j.z != 6) { return 17; }

    // ---- 18-20: a method writes into another object reference ---------
    puts("=== Test 10: method copies into another object ===");
    Vec3 src(7, 8, 9);
    Vec3 dst(0, 0, 0);
    src.copyInto(dst);
    if (dst.x != 7) { return 18; }
    if (dst.y != 8) { return 19; }
    if (dst.z != 9) { return 20; }

    // ---- 21-22: a method reads from another object reference ----------
    puts("=== Test 11: method adds another object into self ===");
    Vec3 p(1, 1, 1);
    Vec3 q(4, 5, 6);
    p.addVec(q);
    if (p.x != 5) { return 21; }
    if (q.x != 4) { return 22; }    // q must be unchanged

    // ---- 23-24: conditional mutation ----------------------------------
    puts("=== Test 12: conditional mutation (true branch) ===");
    Vec3 r(99, 0, 0);
    maybeZeroX(r, true);
    if (r.x != 0) { return 23; }
    puts("=== Test 13: conditional mutation (false branch) ===");
    Vec3 s(99, 0, 0);
    maybeZeroX(s, false);
    if (s.x != 99) { return 24; }

    // ---- 25: loop accumulation through a reference --------------------
    puts("=== Test 14: loop accumulation through a reference ===");
    Vec3 acc(0, 0, 0);
    sumInto(acc, 5);               // 1+2+3+4+5 = 15
    if (acc.x != 15) { return 25; }

    // ---- 26-27: swap fields across two references ---------------------
    puts("=== Test 15: swap fields across references ===");
    Vec3 u(1, 0, 0);
    Vec3 v(2, 0, 0);
    swapX(u, v);
    if (u.x != 2) { return 26; }
    if (v.x != 1) { return 27; }

    // ---- 28: method invoked through a referenced parameter ------------
    puts("=== Test 16: method invoked through a referenced param ===");
    Vec3 w(3, 3, 3);
    scaleThrough(w, 3);
    if (w.x != 9) { return 28; }

    // ---- 29: read fields through a reference --------------------------
    puts("=== Test 17: read fields through a reference ===");
    Vec3 reader(10, 20, 30);
    if (sumOf(reader) != 60) { return 29; }

    // ---- 30: float to int cast (truncates toward zero) ----------------
    puts("=== Test 18: float to int cast ===");
    f32 fv = 3.9 as f32;
    i32 iv = fv as i32;
    if (iv != 3) { return 30; }

    // ---- 31: cast a field read through a reference --------------------
    puts("=== Test 19: cast a field read through a reference ===");
    Box bx(7.8 as f32);
    if (readAsInt(bx) != 7) { return 31; }

    // ---- 32: integer narrowing cast -----------------------------------
    puts("=== Test 20: integer narrowing cast ===");
    i64 big   = 300;
    i32 small = big as i32;
    if (small != 300) { return 32; }

    // ---- 33: mutate through a reference, then read via a method -------
    puts("=== Test 21: mutate via free fn, observe via method ===");
    Vec3 mixedView(2, 2, 2);
    bumpAll(mixedView);            // each field -> 3
    if (mixedView.sum() != 9) { return 33; }

    puts("=== ALL PASS-BY-REFERENCE TESTS PASSED ===");
    return 0;
}
