// e2e/value_copy_test.gg
//
// End-to-end validation of value-object copy semantics (deep copy via clone):
//   * value = value  : deep copy (independent)
//   * value = <init>  : copy initialisation
//   * value = ref     : deref + clone into the value
//   * new Class(value) : clone-to-heap copy constructor
//
// Each check returns a unique number on failure; main returns 0 on success.
//
// Expected result: exit code 0

class Point {
    mut i32 x;
    mut i32 y;
    Point(i32 a, i32 b) { this.x = a; this.y = b; }
}

fn main() -> i32 {

    // ---- value = value : deep copy, independent --------------------
    mut Point p(1, 2);
    mut Point q(9, 9);
    q = p;
    p.x = 100;
    if (q.x != 1) { return 1; }
    if (q.y != 2) { return 2; }

    // ---- copy initialisation --------------------------------------
    Point r = p;                       // p.x is now 100
    if (r.x != 100) { return 3; }
    p.x = 7;
    if (r.x != 100) { return 4; }      // r is independent of p

    // ---- value = ref : deref + clone -------------------------------
    mut Point& heap = new Point(5, 6);
    mut Point v(0, 0);
    v = heap;
    if (v.x != 5) { return 5; }
    if (v.y != 6) { return 6; }
    heap.x = 500;                      // mutating the heap object ...
    if (v.x != 5) { return 7; }        // ... must not affect the snapshot

    // ---- copy initialisation from a reference ----------------------
    mut Point w = heap;                // heap.x is now 500
    if (w.x != 500) { return 8; }

    // ---- clone-to-heap copy constructor ----------------------------
    Point& clone = new Point(w);
    w.x = 1;
    if (clone.x != 500) { return 9; }  // independent heap copy

    return 0;
}
