import "mem.gg";
import "string.gg";

class String {
    public ptr  data;
    public u64  size;

    public String(ptr string) {
        this.size = strlen(string);
        u64 allocSize = this.size + 1;    // +1 for the null terminator
        this.data = malloc(allocSize);
        memcpy(this.data, string, allocSize);
    }
}
