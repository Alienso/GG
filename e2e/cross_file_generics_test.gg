// Generics whose templates are declared in another file.
import "box_lib.gg";

fn main() -> i32 {
    Box<i32>& b = new Box<i32>(42);   // generic class from box_lib.gg
    if (b.get() != 42) { return 1; }

    i32 m = maxT<i32>(10, 99);        // generic function from box_lib.gg
    if (m != 99) { return 2; }

    return 0;
}
