// implicit_this_test.gg
// End-to-end test of implicit `this` — referencing class members without `this.`.
// Exercises: bare field read/write/compound/++, bare static-field read/write, bare
// method calls (instance + static), free-function priority, and bare reference-field
// writes. Returns 0 on success, or the number of the first failing check.
//
// Expected result: exit code 0

// Free function — must take priority over any same-named member (none here, but it
// verifies a bare call resolves to the free function, not a phantom member).
i32 dbl(i32 v) { return v * 2; }

class Counter {
    mut i32 count;
    static mut i32 total;         // class-level, shared

    Counter(i32 start) {
        count = start;            // implicit `this.count = start`
        total = total + 1;        // bare static-field read + write
    }

    void inc()      mut { count = count + 1; }   // bare read + write
    void addN(i32 n) mut { count += n; }         // bare compound assign
    void bump()     mut { count++; }             // bare ++
    void incTwice() mut { inc(); inc(); }        // bare instance-method calls on this
    i32  get()          { return count; }        // bare read
    i32  doubledGet()   { return dbl(get()); }   // free fn (priority) + bare method call

    static i32 getTotal() { return total; }      // bare static-field read
    i32  viaStatic()      { return getTotal(); } // bare static-method call (this-less)
}

// Reference-field writes through implicit `this` (retain/release path).
class Node {
    i32       val;
    mut Node& next;
    Node(i32 x) { val = x; }
    void link(mut Node& n) mut { next = n; }     // bare reference-field write
    i32  nextVal()             { return next.val; } // bare ref-field read + member access
}

i32 main() {
    mut Counter a(10);
    a.inc();                       // 11
    a.addN(4);                     // 15
    a.bump();                      // 16
    if (a.get() != 16)          { return 1; }
    if (a.doubledGet() != 32)   { return 2; }   // dbl(16)
    a.incTwice();                  // 18
    if (a.get() != 18)          { return 3; }

    mut Counter b(0);              // total is now 2
    if (a.viaStatic() != 2)     { return 4; }   // bare static read through an instance method
    if (Counter::getTotal() != 2) { return 5; }

    // ---- bare reference-field write / read ----
    mut Node& h = new Node(1);
    mut Node& t = new Node(2);
    h.link(t);
    if (h.nextVal() != 2)       { return 6; }

    // ---- a local shadows a field: the local wins ----
    if (a.get() != 18)          { return 7; }   // sanity

    return 0;
}
