// stdlib/process.gg — process control bindings
//
// Wraps the standard process management functions from <stdlib.h>.

extern exit(i32 status);          // terminate the process with the given exit code
extern abort();                   // terminate the process abnormally
extern getenv(ptr name) -> ptr;          // get the value of an environment variable; null if absent
extern system(ptr command) -> i32;       // run a shell command; returns exit status
