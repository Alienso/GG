// End-to-end coverage for `ref T` non-owning borrows.
// Returns 0 on success; any mismatch shifts the exit code so a failure is visible.

class Point { mut i32 x; mut i32 y; Point(i32 a, i32 b) { x = a; y = b; } }

// A mutable borrow parameter — mutates through the borrow, no ownership taken.
fn shift(mut ref Point p, i32 dx, i32 dy) {
    p.x = p.x + dx;
    p.y = p.y + dy;
}

// A shared borrow reader.
fn sumOf(ref Point p) -> i32 { return p.x + p.y; }

// Returns a borrow of one of its (owning-reference-backed) arguments — no +1.
fn pick(ref Point a, ref Point b, bool takeFirst) -> ref Point {
    if (takeFirst) { return a; }
    return b;
}

// Generic borrow: `ref T` through monomorphization.
fn ident<T>(ref T item) -> ref T { return item; }

// A primitive borrow (`ref i32`, an lvalue reference like C++ `int&`) returned from a method.
class Cell { mut i32 v; Cell(i32 x) { v = x; } fn slot() -> ref i32 { return v; } }

fn main() -> i32 {
    mut i32 errors = 0;

    // 1. borrow a heap reference, mutate through it
    Point& owner = new Point(1, 2);
    mut ref Point b1 = owner;
    b1.x = 10;
    if (owner.x != 10) { errors = errors + 1; }

    // 2. borrow a stack value object, mutate through it
    mut Point local(3, 4);
    mut ref Point b2 = local;
    shift(b2, 5, 6);
    if (local.x != 8) { errors = errors + 10; }
    if (local.y != 10) { errors = errors + 100; }

    // 3. shared-borrow reader over both heap and stack sources
    if (sumOf(owner) != 12) { errors = errors + 1000; }     // 10 + 2
    if (sumOf(local) != 18) { errors = errors + 10000; }    // 8 + 10

    // 4. return a borrow of a heap object (safe: the owner outlives the call)
    Point& q = new Point(100, 200);
    ref Point chosen = pick(owner, q, false);
    if (chosen.x != 100) { errors = errors + 100000; }

    // 5. generic ref pass-through
    ref Point g = ident<Point>(owner);
    if (g.x != 10) { errors = errors + 1000000; }

    // 6. primitive borrow (`ref i32`): read-through and write-through a field
    mut Cell cell(7);
    mut ref i32 slot = cell.slot();
    slot = slot + 3;                          // read (deref) + write-through
    if (cell.v != 10) { errors = errors + 10000000; }
    ref i32 view = cell.slot();
    if (view != 10) { errors = errors + 100000000; }   // read-through a shared borrow

    // 7. assign directly to a returned primitive borrow (v.at(i) = x)
    mut Cell target(0);
    target.slot() = 99;
    if (target.slot() != 99) { errors = errors + 1000000000; }

    return errors;
}
